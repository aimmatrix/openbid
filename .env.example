# ============================================================================
# OpenBid — environment template. Copy to .env.local and fill in.
# The backend owner manages this file. The frontend teammate needs none of these.
# ============================================================================

# --- LLM (CRITICAL — agent reasoning) ---
# Use ONE of these. Anthropic preferred. Get a key tonight:
#   https://console.anthropic.com/
#   https://platform.openai.com/
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional model override:
# LLM_MODEL=claude-opus-4-7
# OPENAI_MODEL=gpt-4o

# --- Tavily (HIGH — bonus prize, agent grounding) ---
# Free tier exists. Get tonight: https://tavily.com/
TAVILY_API_KEY=

# --- Text-to-video provider (MEDIUM — Tier-2 stretch) ---
# Pick ONE. If none set, /clips/tier2-fallback.mp4 is used (pre-baked).
VIDEO_PROVIDER=fallback   # fallback | runway | luma | pika | veo
RUNWAY_API_KEY=
LUMA_API_KEY=
PIKA_API_KEY=
VEO_API_KEY=

# --- Thrad (HIGH — core sponsor, get from Thrad rep at the event) ---
# Without this, lib/adapters/thrad falls back to mocks/campaigns.ts.
THRAD_API_KEY=
THRAD_BASE_URL=https://api.thrad.com

# --- Overmind (HIGHEST BONUS — get from Overmind rep at the event) ---
# Without this, traces stay in an in-memory buffer (still demoable).
OVERMIND_API_KEY=
OVERMIND_BASE_URL=https://api.overmind.ai

# --- Alpic (LOW — optional bonus, get from Alpic rep if ahead) ---
ALPIC_TOKEN=
ALPIC_ENDPOINT_URL=
