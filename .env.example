# ============================================================================
# OpenBid — environment template. Copy to .env.local and fill in.
# The backend owner manages this file. The frontend teammate needs none of these.
# ============================================================================

# --- LLM (CRITICAL — agent reasoning) ---
# Use ONE of these. Anthropic preferred. Get a key tonight:
#   https://console.anthropic.com/
#   https://platform.openai.com/
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional model override:
# LLM_MODEL=claude-opus-4-7
# OPENAI_MODEL=gpt-4o

# --- Tavily (HIGH — bonus prize, agent grounding) ---
# Free tier exists. Get tonight: https://tavily.com/
TAVILY_API_KEY=

# --- Text-to-video provider (MEDIUM — Tier-2 stretch) ---
# Pick ONE. If none set, /clips/tier2-fallback.mp4 is used (pre-baked).
VIDEO_PROVIDER=fallback   # fallback | runway | luma | pika | veo
RUNWAY_API_KEY=
LUMA_API_KEY=
PIKA_API_KEY=
VEO_API_KEY=

# --- Overmind (HIGHEST BONUS — agent supervision + LLM tracing) ---
# Create project + key at console.overmindlab.ai/projects.
# Without this, traces stay in an in-memory buffer (still demoable).
OVERMIND_API_KEY=
OVERMIND_TRACES_URL=https://api.overmindlab.ai
# DEPLOYMENT_ENVIRONMENT=development

# --- Alpic (live MCP endpoint via Skybridge, deployed from mcp/) ---
# Deploy with `cd mcp && npm run deploy`. The CLI prints a URL like
# https://openbid-mcp-xxxx.alpic.live. Paste that here so the UI + the
# /api/mcp fallback can link judges to the hosted MCP + playground.
ALPIC_ENDPOINT_URL=
ALPIC_PLAYGROUND_URL=
# Duplicate as NEXT_PUBLIC_* so the OpenBid client UI can render the link.
NEXT_PUBLIC_ALPIC_ENDPOINT_URL=
NEXT_PUBLIC_ALPIC_PLAYGROUND_URL=
